const content = serviceContent[service.slug];

// Related services
const relatedServices = content
  ? services.filter(s => content.relatedSlugs.includes(s.slug))
  : [];

// SEO
const seo = {
  title: `${service.name} en Asunción | Dra. Agustina González`,
  description: `${service.name} profesional en Asunción.${service.brand ? ` Tratamiento con ${service.brand}.` : ''} ${service.tagline}. Agendá tu turno.`,
  canonical: `https://agustinagonzalez.com.py/servicios/${service.slug}`
};

// Schema: Service
const schemaService = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": service.name,
  "provider": {
    "@type": "MedicalBusiness",
    "name": "Dra. Agustina González - Dermatocosmiatra",
    "url": "https://agustinagonzalez.com.py"
  },
  "areaServed": { "@type": "City", "name": "Asunción" },
  "description": seo.description,
  "offers": {
    "@type": "Offer",
    "price": service.price.replace(/\./g, '').replace(' Gs', ''),
    "priceCurrency": "PYG"
  }
};

// Schema: FAQPage
const schemaFAQ = content ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": content.faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
} : null;

// Schema: Breadcrumb
const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://agustinagonzalez.com.py/" },
    { "@type": "ListItem", "position": 2, "name": "Servicios", "item": "https://agustinagonzalez.com.py/servicios" },
    { "@type": "ListItem", "position": 3, "name": service.name, "item": seo.canonical }
  ]
};
---

<BaseLayout title={seo.title} description={seo.description} canonical={seo.canonical}>
  <Header slot="header" />

  <!-- Breadcrumbs -->
  <nav class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-6" aria-label="Breadcrumb">
    <ol class="flex text-sm text-text-light gap-2">
      <li><a href="/" class="hover:text-taupe transition-colors">Inicio</a></li>
      <li>/</li>
      <li><a href="/servicios" class="hover:text-taupe transition-colors">Servicios</a></li>
      <li>/</li>
      <li class="text-text font-medium">{service.name}</li>
    </ol>
  </nav>

  {content ? (
    <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <!-- H1 + tagline -->
      <header class="mb-10">
        <h1 class="font-heading text-4xl sm:text-5xl font-semibold text-text mb-4">
          {service.name} en Asunción
        </h1>
        <p class="text-taupe font-medium text-lg">{service.tagline}</p>
      </header>

      <!-- Intro -->
      <section class="mb-12">
        <p class="text-text-light text-lg leading-relaxed">{content.intro}</p>
      </section>

      <!-- ¿Qué es? -->
      <section class="mb-12">
        <h2 class="font-heading text-2xl sm:text-3xl font-semibold text-text mb-4">¿Qué es {service.name.toLowerCase().startsWith('el ') || service.name.toLowerCase().startsWith('la ') ? '' : service.name.includes('Tratamiento') || service.name.includes('Mesoterapia') || service.name.includes('Limpieza') ? 'la ' : 'el '}{service.name.toLowerCase()}?</h2>
        <p class="text-text-light leading-relaxed">{content.whatIs}</p>
      </section>

      <!-- Beneficios -->
      <section class="mb-12">
        <h2 class="font-heading text-2xl sm:text-3xl font-semibold text-text mb-6">Beneficios</h2>
        <ul class="space-y-3">
          {content.benefits.map((benefit) => (
            <li class="flex items-start gap-3">
              <span class="text-taupe mt-1 shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="text-text-light">{benefit}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Proceso -->
      <section class="mb-12">
        <h2 class="font-heading text-2xl sm:text-3xl font-semibold text-text mb-4">¿Cómo es la sesión?</h2>
        <p class="text-text-light leading-relaxed">{content.process}</p>
      </section>

      <!-- Marca -->
      <section class="mb-12">
        <h2 class="font-heading text-2xl sm:text-3xl font-semibold text-text mb-4">Productos que utilizamos</h2>
        <p class="text-text-light leading-relaxed">{content.brandText}</p>
      </section>

      <!-- Precio -->
      <section class="mb-14">
        <div class="border-y border-cream-dark">
          <div class="grid grid-cols-2 sm:grid-cols-3 divide-x divide-cream-dark">
            <div class="py-6 px-8">
              <p class="label-overline mb-2">Precio por sesión</p>
              <p class="font-heading text-2xl font-normal text-text">{service.price}</p>
            </div>
            <div class="py-6 px-8">
              <p class="label-overline mb-2">Duración</p>
              <p class="font-heading text-2xl font-normal text-text">{service.duration}</p>
            </div>
            {service.brand && (
              <div class="py-6 px-8 col-span-2 sm:col-span-1 border-t sm:border-t-0 border-cream-dark">
                <p class="label-overline mb-2">Producto</p>
                <p class="font-heading text-lg font-normal text-text">{service.brand}</p>
              </div>
            )}
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="mb-12">
        <h2 class="font-heading text-2xl sm:text-3xl font-semibold text-text mb-6">Preguntas frecuentes</h2>
        <div class="space-y-6">
          {content.faqs.map((faq) => (
            <details class="group border-b border-cream-dark/50 pb-4">
              <summary class="cursor-pointer list-none flex items-start justify-between gap-4 font-medium text-text hover:text-taupe transition-colors">
                <span>{faq.question}</span>
                <span class="text-taupe shrink-0 mt-1 group-open:rotate-45 transition-transform">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </span>
              </summary>
              <p class="mt-3 text-text-light leading-relaxed">{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- CTA -->
      <section class="mb-14 border-y border-cream-dark py-14">
        <div class="text-center">
          <div class="divider-taupe mb-8"></div>
          <p class="label-overline mb-4">Siguiente paso</p>
          <h2 class="font-heading text-2xl sm:text-3xl font-normal text-text mb-3">
            ¿Querés saber si este tratamiento es ideal para tu piel?
          </h2>
          <p class="text-text-light mb-8 max-w-sm mx-auto text-sm leading-relaxed">
            Escribime por WhatsApp y agendamos una consulta personalizada.
          </p>
          <a
            href="https://wa.me/595971614156"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary-wa"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Agendá tu turno por WhatsApp
          </a>
        </div>
      </section>

      <!-- Related services -->
      {relatedServices.length > 0 && (
        <section>
          <h2 class="font-heading text-2xl sm:text-3xl font-semibold text-text mb-6">Tratamientos relacionados</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {relatedServices.map((related) => (
              <ServiceCard slug={related.slug} name={related.name} tagline={related.tagline} price={related.price} brand={related.brand} />
            ))}
          </div>
        </section>
      )}
    </article>
  ) : (
    <div class="max-w-4xl mx-auto px-4 py-12 text-center">
      <p class="text-text-light">Contenido en preparación. Contactanos para más información sobre este servicio.</p>
    </div>
  )}

  <!-- Schema markup -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaService)} />
  {schemaFAQ && <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />}
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />

  <Footer slot="footer" />
</BaseLayout>
