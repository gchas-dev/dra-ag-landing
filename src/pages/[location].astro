---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceCard from '../components/ServiceCard.astro';
import locations from '../data/locations.json';
import services from '../content/services.json';

export function getStaticPaths() {
  return locations.map((loc) => ({
    params: { location: loc.slug },
    props: { loc }
  }));
}

const { loc } = Astro.props;

const featuredServices = loc.featuredServices
  .map(slug => services.find(s => s.slug === slug))
  .filter(Boolean);

const allServices = services.filter(s =>
  ['mesoterapia-facial-asuncion','tratamiento-antiaging-asuncion','exosomas-mediderma-asuncion',
   'cellbooster-glow-asuncion','plasma-rico-plaquetas-asuncion','pdrn-salmon-mediderma-asuncion',
   'tratamiento-ojeras-asuncion','limpieza-facial-profunda-asuncion'].includes(s.slug)
);

const seo = {
  title: `Estética Facial en ${loc.city} | Dra. Agustina González — Asunción`,
  description: `Tratamientos faciales profesionales para pacientes de ${loc.city}. A ${loc.distance} minutos del consultorio en Asunción. Mesoterapia, antiaging, exosomas y más. Agendá tu turno.`,
  canonical: `https://agustinagonzalez.com.py/${loc.slug}`
};

const schemaService = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "name": "Dra. Agustina González - Dermatocosmiatra",
  "url": "https://agustinagonzalez.com.py",
  "telephone": "+595971614156",
  "areaServed": [
    { "@type": "City", "name": "Asunción" },
    { "@type": "City", "name": loc.city }
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Ing. Prof. Nicolás Krisvoschein",
    "addressLocality": "Asunción",
    "addressRegion": "Central",
    "addressCountry": "PY"
  }
};

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://agustinagonzalez.com.py/" },
    { "@type": "ListItem", "position": 2, "name": `Estética Facial en ${loc.city}`, "item": seo.canonical }
  ]
};
---

<BaseLayout title={seo.title} description={seo.description} canonical={seo.canonical}>
  <Header slot="header" />

  <!-- Breadcrumb -->
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-6" aria-label="Breadcrumb">
    <ol class="flex text-sm text-text-light gap-2">
      <li><a href="/" class="hover:text-taupe transition-colors">Inicio</a></li>
      <li>/</li>
      <li class="text-text font-medium">Estética Facial en {loc.city}</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="py-20 sm:py-24 bg-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="label-overline mb-4">{loc.region} · A {loc.distance} minutos</p>
        <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-normal text-text leading-tight mb-4">
          Estética Facial<br/>
          <em class="not-italic" style="color: var(--color-taupe-deep)">en {loc.city}</em>
        </h1>
        <div class="w-10 h-px bg-taupe mb-6"></div>
        <p class="text-text-light text-lg leading-relaxed max-w-2xl mb-8">
          {loc.intro}
        </p>
        <a
          href="https://wa.me/595971614156"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary-wa"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Agendá tu turno desde {loc.city}
        </a>
      </div>
    </div>
  </section>

  <!-- Por qué venir desde loc.city -->
  <section class="py-20 bg-white-off">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-start">
        <div>
          <p class="label-overline mb-4">Por qué elegimos</p>
          <h2 class="font-heading text-3xl sm:text-4xl font-normal text-text mb-4">
            Pacientes de {loc.city} que eligen la Dra. González
          </h2>
          <div class="w-8 h-px bg-taupe mb-6"></div>
          <p class="text-text-light leading-relaxed mb-6">{loc.context}</p>
          <p class="text-text-light leading-relaxed">
            La Dra. Agustina González es Odontóloga y Dermatocosmiatra, actualmente cursando un posgrado en Armonización Orofacial. Trabaja exclusivamente con marcas internacionales como Mesoestetic, Mediderma, Cellbooster y Janssen Cosmetics.
          </p>
        </div>
        <div class="grid grid-cols-1 gap-px bg-cream-dark">
          <div class="bg-white-off p-6">
            <p class="label-overline mb-2">Distancia</p>
            <p class="font-heading text-3xl font-normal text-text">{loc.distance} min</p>
            <p class="text-text-light text-sm mt-1">desde {loc.city} hasta el consultorio</p>
          </div>
          <div class="bg-white-off p-6">
            <p class="label-overline mb-2">Ubicación</p>
            <p class="font-heading text-lg font-normal text-text">Airea Clínica Boutique</p>
            <p class="text-text-light text-sm mt-1">Barrio Santísima Trinidad, Asunción</p>
          </div>
          <div class="bg-white-off p-6">
            <p class="label-overline mb-2">Atención</p>
            <p class="font-heading text-lg font-normal text-text">Con turno previo</p>
            <p class="text-text-light text-sm mt-1">Agendá por WhatsApp</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tratamientos destacados para esta ciudad -->
  <section class="py-20 bg-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <p class="label-overline mb-4">Más consultados desde {loc.city}</p>
        <h2 class="font-heading text-3xl sm:text-4xl font-normal text-text">Tratamientos destacados</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-px bg-cream-dark">
        {featuredServices.map((service) => (
          <ServiceCard
            slug={service.slug}
            name={service.name}
            tagline={service.tagline}
            price={service.price}
            brand={service.brand}
          />
        ))}
      </div>
      <div class="mt-8">
        <a href="/servicios" class="btn-text">
          Ver todos los tratamientos
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-white-off">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl sm:text-4xl font-normal text-text mb-4 leading-tight">
        ¿Venís desde {loc.city}? Agendá tu turno hoy
      </h2>
      <p class="text-text-light mb-8">
        Escribime por WhatsApp y coordinamos el día y horario que mejor te quede.
      </p>
      <div class="divider-taupe mb-8"></div>
      <a
        href="https://wa.me/595971614156"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary-wa"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Escribime por WhatsApp
      </a>
    </div>
  </section>

  <!-- Otras ciudades -->
  <section class="py-16 bg-cream border-t border-cream-dark">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="label-overline mb-6">También atendemos pacientes de</p>
      <div class="flex flex-wrap gap-3">
        {locations.filter(l => l.slug !== loc.slug).map(l => (
          <a href={`/${l.slug}`} class="border border-cream-dark bg-white-off px-4 py-2 text-sm text-text-secondary hover:border-taupe transition-colors">
            {l.city}
          </a>
        ))}
        <a href="/contacto" class="border border-taupe/40 bg-cream px-4 py-2 text-sm text-text-secondary hover:border-taupe transition-colors">
          Otra ciudad →
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schemaService)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />

  <Footer slot="footer" />
</BaseLayout>
