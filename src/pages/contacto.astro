---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const seo = {
  title: "Contacto | Dra. Agustina González — Dermatocosmiatra en Asunción",
  description: "Agendá tu turno con la Dra. Agustina González. Consultorio en Airea Clínica Boutique, Barrio Santísima Trinidad, Asunción. WhatsApp: 0971 614156.",
  canonical: "https://agustinagonzalez.com.py/contacto"
};
---

<BaseLayout title={seo.title} description={seo.description} canonical={seo.canonical}>
  <Header slot="header" />

  <!-- Breadcrumbs -->
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-6" aria-label="Breadcrumb">
    <ol class="flex text-sm text-text-light gap-2">
      <li><a href="/" class="hover:text-taupe transition-colors">Inicio</a></li>
      <li>/</li>
      <li class="text-text font-medium">Contacto</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-8">
    <h1 class="font-heading text-4xl sm:text-5xl font-semibold text-text mb-4">Contacto</h1>
    <p class="text-text-light text-lg max-w-2xl">
      Estoy para ayudarte. Escribime por WhatsApp para agendar tu consulta o resolver cualquier duda sobre los tratamientos.
    </p>
  </section>

  <!-- Contact grid -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- Contact info -->
      <div class="space-y-8">
        <!-- WhatsApp (primary CTA) -->
        <div class="bg-white-off border border-cream-dark/50 rounded-2xl p-6">
          <h2 class="font-heading text-xl font-semibold text-text mb-3">WhatsApp</h2>
          <p class="text-text-light text-sm mb-4">La forma más rápida de contactarme. Respondemos dentro de las 24 horas.</p>
          <a
            href="https://wa.me/595971614156"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#20BD5A] text-white font-medium px-6 py-3 rounded-full transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Escribime por WhatsApp
          </a>
        </div>

        <!-- Location -->
        <div class="bg-white-off border border-cream-dark/50 rounded-2xl p-6">
          <h2 class="font-heading text-xl font-semibold text-text mb-3">Consultorio</h2>
          <address class="not-italic text-text-light text-sm space-y-2">
            <p class="font-medium text-text">Airea Clínica Boutique</p>
            <p>Ing. Prof. Nicolás Krisvoschein</p>
            <p>Barrio Santísima Trinidad, Asunción, Paraguay</p>
          </address>
        </div>

        <!-- Phone -->
        <div class="bg-white-off border border-cream-dark/50 rounded-2xl p-6">
          <h2 class="font-heading text-xl font-semibold text-text mb-3">Teléfono</h2>
          <a href="tel:+595971614156" class="text-text-light hover:text-taupe transition-colors text-sm">
            0971 614156
          </a>
        </div>

        <!-- Hours -->
        <div class="bg-white-off border border-cream-dark/50 rounded-2xl p-6">
          <h2 class="font-heading text-xl font-semibold text-text mb-3">Horarios de atención</h2>
          <p class="text-text-light text-sm">Consultar disponibilidad por WhatsApp. Atención con turno previo.</p>
        </div>
      </div>

      <!-- Map -->
      <div class="rounded-2xl overflow-hidden border border-cream-dark/50 h-[400px] lg:h-auto lg:min-h-[500px]">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3607.5!2d-57.5648463!3d-25.2698416!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x945da8a0ecb0c5f1%3A0x0!2zMjXCsDE2JzExLjQiUyA1N8KwMzMnNTMuNCJX!5e0!3m2!1ses!2spy!4v1"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación del consultorio de la Dra. Agustina González en Asunción"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Breadcrumb Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://agustinagonzalez.com.py/" },
      { "@type": "ListItem", "position": 2, "name": "Contacto", "item": "https://agustinagonzalez.com.py/contacto" }
    ]
  })} />

  <Footer slot="footer" />
</BaseLayout>
