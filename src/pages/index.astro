---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceCard from '../components/ServiceCard.astro';
import services from '../content/services.json';

const featuredServices = services.filter(s => s.featured);

const waIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`;
---

<BaseLayout
  title="Dra. Agustina González - Estética Facial en Asunción"
  description="Tratamientos faciales personalizados en Asunción. Mesoterapia, antiaging, exosomas y más. Resultados naturales y seguros. Agendá tu turno."
  canonical="https://agustinagonzalez.com.py/"
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="relative bg-cream overflow-hidden">
    <!-- Texture -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: url('data:image/svg+xml,<svg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;><g fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;><g fill=&quot;%23000000&quot;><path d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/></g></g></svg>')"></div>

    <!-- Monograma decorativo — solo desktop -->
    <div class="absolute right-0 top-0 bottom-0 w-1/2 items-center justify-center pointer-events-none overflow-hidden hidden lg:flex">
      <img
        src="/images/monograma-ag.png"
        alt=""
        aria-hidden="true"
        class="w-[520px] h-[520px] object-contain select-none"
        style="opacity: 0.055; filter: brightness(0) saturate(100%) invert(75%) sepia(10%) saturate(400%) hue-rotate(10deg) brightness(90%); transform: translateX(80px);"
      />
    </div>
    <!-- Línea divisoria vertical sutil -->
    <div class="absolute right-1/2 top-1/4 bottom-1/4 w-px bg-taupe/10 hidden lg:block pointer-events-none"></div>
    <!-- Gradiente esquina -->
    <div class="absolute bottom-0 right-0 w-64 h-64 opacity-20 pointer-events-none" style="background: radial-gradient(circle at 100% 100%, var(--color-taupe) 0%, transparent 70%)"></div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-28 sm:pt-32 sm:pb-36 relative">
      <div class="max-w-3xl">
        <h1 class="label-overline mb-6 animate-hero">Estética Facial en Asunción</h1>
        <p class="font-heading text-5xl sm:text-6xl lg:text-7xl font-normal text-text leading-[1.08] mb-8 animate-hero-delay-1">
          Tu cara merece<br/>
          <em class="not-italic" style="color: var(--color-taupe-deep)">un cuidado</em><br/>
          profesional
        </p>
        <div class="w-10 h-px bg-taupe mb-8 animate-hero-delay-2"></div>
        <p class="text-text-light text-lg leading-relaxed mb-10 max-w-xl animate-hero-delay-2">
          Tratamientos faciales personalizados con productos de laboratorios europeos líderes.
          Resultados naturales y seguros en un espacio pensado para tu bienestar.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 animate-hero-delay-3">
          <a
            href="https://wa.me/595971614156"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            Agendá tu turno
          </a>
          <a href="/servicios" class="btn-secondary">
            Ver tratamientos
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- About preview -->
  <section class="py-24 bg-white-off">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center reveal">
        <div class="relative">
          <img
            src="/images/dra-agustina-gonzalez.webp"
            alt="Dra. Agustina González, dermatocosmiatra en Asunción"
            class="w-full aspect-[3/4] object-cover rounded-sm"
            loading="lazy"
            fetchpriority="high"
            width="675"
            height="900"
          />
          <div class="absolute -bottom-3 -right-3 w-full h-full border border-taupe/30 rounded-sm -z-10"></div>
        </div>
        <div>
          <p class="label-overline mb-4">Sobre mí</p>
          <h2 class="font-heading text-4xl sm:text-5xl font-normal text-text mb-2">
            Dra. Agustina González
          </h2>
          <div class="w-8 h-px bg-taupe mb-6"></div>
          <p class="text-text-light leading-relaxed mb-4">
            Odontóloga y Dermatocosmiatra con formación internacional. Mi doble formación me da una visión integral de la armonía facial que pocas profesionales pueden ofrecer.
          </p>
          <p class="text-text-light leading-relaxed mb-8">
            Actualmente cursando un posgrado en Armonización Orofacial, trabajo exclusivamente con marcas premium como Mesoestetic, Mediderma, Janssen Cosmetics y Cellbooster.
          </p>
          <a href="/sobre-mi" class="btn-text">
            Conocé mi historia
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Services -->
  <section class="py-24 bg-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14 reveal">
        <p class="label-overline mb-4">Tratamientos</p>
        <h2 class="font-heading text-4xl sm:text-5xl font-normal text-text">
          Servicios destacados
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-cream-dark reveal">
        {featuredServices.map((service) => (
          <ServiceCard
            slug={service.slug}
            name={service.name}
            tagline={service.tagline}
            price={service.price}
            brand={service.brand}
          />
        ))}
      </div>
      <div class="mt-10 reveal">
        <a href="/servicios" class="btn-text">
          Ver todos los tratamientos
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Trust / Brands -->
  <section class="py-24 bg-white-off border-y border-cream-dark reveal">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-center gap-10">
        <div class="md:w-1/3">
          <p class="label-overline mb-4">Calidad premium</p>
          <h2 class="font-heading text-3xl sm:text-4xl font-normal text-text leading-tight">
            Productos de laboratorios internacionales
          </h2>
        </div>
        <div class="md:w-2/3 grid grid-cols-2 sm:grid-cols-4 gap-4">
          {['Mesoestetic', 'Mediderma', 'Janssen Cosmetics', 'Cellbooster'].map((brand) => (
            <div class="border border-cream-dark py-5 px-4 flex items-center justify-center text-center">
              <span class="font-heading text-base text-text-secondary tracking-wide">{brand}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="py-28 bg-cream reveal">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-4xl sm:text-5xl font-normal text-text mb-6 leading-tight">
        ¿Querés saber qué tratamiento es ideal para tu piel?
      </h2>
      <p class="text-text-light text-lg mb-8">
        Escribime por WhatsApp y agendamos una consulta personalizada.
      </p>
      <div class="divider-taupe mb-8"></div>
      <a
        href="https://wa.me/595971614156"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary-wa"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Escribime por WhatsApp
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('is-visible');
        observer.unobserve(e.target);
      }
    }),
    { threshold: 0.1 }
  );
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
