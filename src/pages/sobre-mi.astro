---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const waUrl = `https://wa.me/595971614156?text=${encodeURIComponent('Hola! Quiero agendar una consulta con la Dra. González. ¿Cuándo tienen disponibilidad?')}`;
---

<BaseLayout
  title="Sobre la Dra. Agustina González | Dermatocosmiatra en Asunción"
  description="Conocé a la Dra. Agustina González. Odontóloga y dermatocosmiatra con formación internacional. Especialista en estética facial en Asunción, Paraguay."
  canonical="https://agustinagonzalez.com.py/sobre-mi"
>
  <Header slot="header" />

  <!-- Hero bio -->
  <section class="py-20 sm:py-28 bg-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 items-center reveal">
        <div class="relative">
          <img
            src="/images/dra-agustina-gonzalez.webp"
            alt="Dra. Agustina González, dermatocosmiatra en Asunción"
            class="w-full aspect-[3/4] object-cover rounded-sm"
            loading="eager"
            fetchpriority="high"
            width="675"
            height="900"
          />
          <div class="absolute -bottom-3 -right-3 w-full h-full border border-taupe/30 rounded-sm -z-10"></div>
        </div>
        <div>
          <p class="label-overline mb-4">Sobre mí</p>
          <h1 class="font-heading text-4xl sm:text-5xl font-normal text-text mb-2">
            Dra. Agustina González — Dermatocosmiatra en Asunción
          </h1>
          <div class="w-8 h-px bg-taupe mb-6"></div>
          <p class="text-text-light leading-relaxed mb-4">
            Soy Odontóloga egresada de la Universidad Nacional del Nordeste (República Argentina) y Dermatocosmiatra. Mi camino en la estética facial comenzó con la convicción de que cada persona merece cuidar su cara sin intervenciones invasivas ni resultados artificiales.
          </p>
          <p class="text-text-light leading-relaxed mb-4">
            Mi doble formación me da una visión integral de la armonía facial. Entiendo la estructura ósea, la musculatura y la piel como un todo — y eso se refleja en cada resultado.
          </p>
          <p class="text-text-light leading-relaxed">
            Actualmente curso un posgrado en Armonización Orofacial en la Universidad Central del Paraguay, porque creo que la actualización constante es parte del mejor cuidado.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mi enfoque — bloques numerados -->
  <section class="py-24 bg-white-off">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14 reveal">
        <p class="label-overline mb-4">Mi filosofía</p>
        <h2 class="font-heading text-4xl sm:text-5xl font-normal text-text">Mi enfoque</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-px bg-cream-dark">
        <div class="bg-white-off p-8 sm:p-10 reveal">
          <span class="font-heading text-6xl font-normal leading-none block mb-6 select-none" style="color: var(--color-cream-dark);" aria-hidden="true">01</span>
          <h3 class="font-heading text-lg font-normal text-text mb-3">Resultados seguros</h3>
          <div class="w-6 h-px bg-taupe mb-4"></div>
          <p class="text-text-light text-sm leading-relaxed">
            Trabajo solo con productos aprobados y técnicas respaldadas por evidencia científica. Tu seguridad siempre es lo primero.
          </p>
        </div>
        <div class="bg-white-off p-8 sm:p-10 reveal reveal-delay-1">
          <span class="font-heading text-6xl font-normal leading-none block mb-6 select-none" style="color: var(--color-cream-dark);" aria-hidden="true">02</span>
          <h3 class="font-heading text-lg font-normal text-text mb-3">Naturalidad</h3>
          <div class="w-6 h-px bg-taupe mb-4"></div>
          <p class="text-text-light text-sm leading-relaxed">
            Mi objetivo es que te veas renovada, no diferente. Tratamientos que respetan tu belleza natural y la potencian.
          </p>
        </div>
        <div class="bg-white-off p-8 sm:p-10 reveal reveal-delay-2">
          <span class="font-heading text-6xl font-normal leading-none block mb-6 select-none" style="color: var(--color-cream-dark);" aria-hidden="true">03</span>
          <h3 class="font-heading text-lg font-normal text-text mb-3">Atención personalizada</h3>
          <div class="w-6 h-px bg-taupe mb-4"></div>
          <p class="text-text-light text-sm leading-relaxed">
            Cada piel es única. Por eso cada tratamiento se diseña a medida, después de evaluar tus necesidades específicas.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Formación — timeline vertical -->
  <section class="py-24 bg-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-14 reveal">
        <p class="label-overline mb-4">Trayectoria académica</p>
        <h2 class="font-heading text-4xl sm:text-5xl font-normal text-text">Formación</h2>
      </div>
      <div class="max-w-2xl">
        <div class="relative">
          <!-- Línea vertical -->
          <div class="absolute left-[27px] top-0 bottom-0 w-px bg-taupe/30 pointer-events-none"></div>

          <!-- 01 -->
          <div class="relative flex gap-8 mb-10 reveal">
            <div class="shrink-0 w-14 h-14 border border-taupe/40 bg-cream flex items-center justify-center">
              <span class="font-heading text-sm font-normal text-taupe-deep">01</span>
            </div>
            <div class="pt-3">
              <h3 class="font-heading text-lg font-normal text-text mb-1">Odontología</h3>
              <p class="text-text-light text-sm">Universidad Nacional del Nordeste — República Argentina</p>
            </div>
          </div>

          <!-- 02 -->
          <div class="relative flex gap-8 mb-10 reveal reveal-delay-1">
            <div class="shrink-0 w-14 h-14 border border-taupe/40 bg-cream flex items-center justify-center">
              <span class="font-heading text-sm font-normal text-taupe-deep">02</span>
            </div>
            <div class="pt-3">
              <h3 class="font-heading text-lg font-normal text-text mb-1">Dermatocosmiatría</h3>
              <p class="text-text-light text-sm">Formación en estética facial avanzada</p>
            </div>
          </div>

          <!-- 03 — En curso -->
          <div class="relative flex gap-8 reveal reveal-delay-2">
            <div class="shrink-0 w-14 h-14 border flex items-center justify-center" style="border-color: var(--color-gold); background: var(--color-cream);">
              <span class="font-heading text-sm font-normal" style="color: var(--color-gold);">03</span>
            </div>
            <div class="pt-3">
              <div class="flex flex-wrap items-center gap-3 mb-1">
                <h3 class="font-heading text-lg font-normal text-text">Armonización Orofacial</h3>
                <span class="text-[0.6rem] font-bold tracking-widest uppercase px-2 py-0.5 border" style="border-color: var(--color-gold); color: var(--color-gold);">En curso</span>
              </div>
              <p class="text-text-light text-sm">Posgrado — Universidad Central del Paraguay</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tratamientos que ofrezco -->
  <section class="py-24 bg-cream reveal">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <p class="label-overline mb-4">Lo que hago</p>
        <h2 class="font-heading text-3xl sm:text-4xl font-normal text-text">Tratamientos</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { href: '/servicios/mesoterapia-facial-asuncion', label: 'Mesoterapia Facial' },
          { href: '/servicios/tratamiento-antiaging-asuncion', label: 'Tratamiento Antiaging' },
          { href: '/servicios/exosomas-mediderma-asuncion', label: 'Exosomas Mediderma' },
          { href: '/servicios/cellbooster-glow-asuncion', label: 'Cellbooster Glow' },
          { href: '/servicios/pdrn-salmon-mediderma-asuncion', label: 'PDRN de Salmón Mediderma' },
          { href: '/servicios/plasma-rico-plaquetas-asuncion', label: 'Plasma Rico en Plaquetas' },
          { href: '/servicios/tratamiento-ojeras-asuncion', label: 'Tratamiento de Ojeras' },
          { href: '/servicios/limpieza-facial-profunda-asuncion', label: 'Limpieza Profunda + Peeling' },
          { href: '/servicios/mesoterapia-despigmentante-asuncion', label: 'Mesoterapia Despigmentante' },
        ].map(({ href, label }) => (
          <a href={href} class="border border-cream-dark bg-white-off px-5 py-4 text-sm text-text-secondary hover:border-taupe transition-colors flex items-center justify-between gap-2 group">
            {label}
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-40 group-hover:opacity-100 transition-opacity shrink-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        ))}
      </div>
      <div class="mt-6">
        <a href="/servicios" class="btn-text">Ver todos los tratamientos
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-28 bg-white-off reveal">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-4xl sm:text-5xl font-normal text-text mb-6 leading-tight">
        ¿Querés agendar una consulta?
      </h2>
      <p class="text-text-light text-lg mb-8">
        Escribime por WhatsApp y coordinamos tu primera visita.
      </p>
      <div class="divider-taupe mb-8"></div>
      <a
        href={waUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary-wa"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Agendá tu turno por WhatsApp
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('is-visible');
        observer.unobserve(e.target);
      }
    }),
    { threshold: 0.1 }
  );
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
