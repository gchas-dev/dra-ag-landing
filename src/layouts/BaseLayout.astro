---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = '/images/og-default.webp'
} = Astro.props;

const siteName = 'Dra. Agustina González - Estética Facial en Asunción';

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "@id": "https://agustinagonzalez.com.py/#business",
  "name": "Dra. Agustina González - Dermatocosmiatra",
  "description": "Dermatocosmiatra en Asunción, Paraguay. Tratamientos faciales personalizados: mesoterapia, antiaging, exosomas, plasma rico en plaquetas y más. Productos de laboratorios internacionales premium.",
  "url": "https://agustinagonzalez.com.py",
  "telephone": "+595 971 614156",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Ing. Prof. Nicolás Krisvoschein",
    "addressLocality": "Asunción",
    "addressRegion": "Central",
    "addressCountry": "PY"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -25.2698416,
    "longitude": -57.5648463
  },
  "image": "https://agustinagonzalez.com.py/images/dra-agustina-gonzalez.webp",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Tuesday", "Thursday"],
      "opens": "09:00",
      "closes": "18:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "09:00",
      "closes": "12:00"
    }
  ],
  "areaServed": [
    { "@type": "City", "name": "Asunción" },
    { "@type": "City", "name": "San Lorenzo" },
    { "@type": "City", "name": "Luque" },
    { "@type": "City", "name": "Lambaré" },
    { "@type": "City", "name": "Fernando de la Mora" },
    { "@type": "City", "name": "Mariano Roque Alonso" },
    { "@type": "City", "name": "Villa Elisa" },
    { "@type": "City", "name": "Capiatá" }
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Tratamientos de estética facial",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "MedicalProcedure", "name": "Mesoterapia Facial" }, "price": "600000", "priceCurrency": "PYG" },
      { "@type": "Offer", "itemOffered": { "@type": "MedicalProcedure", "name": "Tratamiento Antiaging" }, "price": "1000000", "priceCurrency": "PYG" },
      { "@type": "Offer", "itemOffered": { "@type": "MedicalProcedure", "name": "Exosomas Mediderma" }, "price": "1200000", "priceCurrency": "PYG" },
      { "@type": "Offer", "itemOffered": { "@type": "MedicalProcedure", "name": "Plasma Rico en Plaquetas" }, "price": "800000", "priceCurrency": "PYG" },
      { "@type": "Offer", "itemOffered": { "@type": "MedicalProcedure", "name": "Limpieza Facial Profunda" }, "price": "350000", "priceCurrency": "PYG" }
    ]
  },
  "priceRange": "Gs 350.000 – Gs 1.300.000",
  "sameAs": [
    "https://www.instagram.com/draagustinagonzalez",
    "https://www.facebook.com/61580337374705/"
  ]
};
---

<!DOCTYPE html>
<html lang="es-PY">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="google-site-verification" content="SYjcl3wmlTyUSDKFPkw3XvDlzSnbxmB0gQn2QRVbaHw" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Dra. Agustina González - Estética Facial en Asunción, Paraguay" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_PY" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="512x512" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lustria&family=Lato:ital,wght@0,300;0,400;0,700;0,900;1,400&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Lustria&family=Lato:ital,wght@0,300;0,400;0,700;0,900;1,400&display=swap" rel="stylesheet" />
    </noscript>

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
  </head>
  <body class="min-h-screen flex flex-col">
    <slot name="header">
      <header />
    </slot>

    <main class="flex-1">
      <slot />
    </main>

    <slot name="footer">
      <footer />
    </slot>

    <!-- WhatsApp floating button -->
    <a
      href="https://wa.me/595971614156"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Escribinos por WhatsApp"
      class="fixed bottom-6 right-6 z-50 bg-[#25D366] hover:bg-[#20BD5A] text-white rounded-full w-14 h-14 flex items-center justify-center shadow-lg transition-transform hover:scale-110"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>
  </body>
</html>
