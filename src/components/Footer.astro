---
const locations = [
  { href: '/estetica-facial-san-lorenzo', label: 'San Lorenzo' },
  { href: '/estetica-facial-luque', label: 'Luque' },
  { href: '/estetica-facial-lambae', label: 'Lambaré' },
  { href: '/estetica-facial-fernando-de-la-mora', label: 'Fernando de la Mora' },
  { href: '/estetica-facial-villa-elisa', label: 'Villa Elisa' },
  { href: '/estetica-facial-capiata', label: 'Capiatá' },
];

const services = [
  { href: '/servicios/mesoterapia-facial-asuncion', label: 'Mesoterapia Facial' },
  { href: '/servicios/tratamiento-antiaging-asuncion', label: 'Tratamiento Antiaging' },
  { href: '/servicios/exosomas-mediderma-asuncion', label: 'Exosomas Mediderma' },
  { href: '/servicios/limpieza-facial-profunda-asuncion', label: 'Limpieza Profunda' },
  { href: '/servicios/tratamiento-ojeras-asuncion', label: 'Tratamiento de Ojeras' },
  { href: '/servicios/plasma-rico-plaquetas-asuncion', label: 'Plasma Rico en Plaquetas' },
];

const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-footer-bg)] text-[var(--color-footer-text)]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <!-- Brand -->
      <div>
        <h3 class="font-heading text-2xl font-normal mb-1 text-[var(--color-footer-heading)]">Dra. Agustina González</h3>
        <p class="text-xs tracking-widest uppercase mb-5 text-[var(--color-footer-muted)]">Estética Facial · Asunción, PY</p>
        <p class="text-sm leading-relaxed mb-6 text-[var(--color-footer-text)]">
          Tratamientos faciales personalizados con productos premium internacionales. Resultados naturales y seguros.
        </p>
        <div class="flex gap-4">
          <a href="https://www.instagram.com/draagustinagonzalez" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-[var(--color-footer-muted)] hover:opacity-80 transition-opacity">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="https://www.facebook.com/61580337374705/" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-[var(--color-footer-muted)] hover:opacity-80 transition-opacity">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-xs font-bold tracking-widest uppercase mb-5 text-[var(--color-footer-muted)]">Servicios</h4>
        <ul class="space-y-2.5">
          {services.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm hover:opacity-80 transition-opacity text-[var(--color-footer-text)]">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Locations -->
      <div class="hidden md:block">
        <h4 class="text-xs font-bold tracking-widest uppercase mb-5 text-[var(--color-footer-muted)]">También desde</h4>
        <ul class="space-y-2.5">
          {locations.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm hover:opacity-80 transition-opacity text-[var(--color-footer-text)]">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact / NAP -->
      <div>
        <h4 class="text-xs font-bold tracking-widest uppercase mb-5 text-[var(--color-footer-muted)]">Contacto</h4>
        <address class="not-italic text-sm space-y-3 text-[var(--color-footer-text)]">
          <p>
            <span class="font-medium text-[var(--color-footer-heading)]">Consultorio</span><br />
            Airea Clínica Boutique<br />
            Ing. Prof. Nicolás Krisvoschein<br />
            Barrio Santísima Trinidad, Asunción
          </p>
          <p>
            <a href="https://maps.app.goo.gl/RRkuFBYbrfUZVyvd6" target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity">Ver en Mapa →</a>
          </p>
          <p>
            <a href="https://wa.me/595971614156" target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity">+595 (971) 614156</a>
          </p>
          <p>
            <a href="https://wa.me/595971614156" target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity">Escribime por WhatsApp →</a>
          </p>
        </address>
      </div>
    </div>

    <div class="border-t pt-6 text-xs text-center border-[var(--color-footer-border)] text-[var(--color-footer-copyright)]">
      <p>&copy; {year} Dra. Agustina González. Todos los derechos reservados. &nbsp;·&nbsp; <a href="/politica-de-privacidad" class="hover:opacity-80 transition-opacity">Política de Privacidad</a></p>
    </div>
  </div>
</footer>
